{
	"name": "@remato/submodule-status-commenter",
	"version": "3.0.0",
	"license": "MIT",
	"description": "GitHub action to comment submodules current branch and state to the PR",
	"main": "dist/index.js",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js",
		"prettier": "prettier --list-different \"**/*.ts\"",
		"lint": "oxlint",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@actions/core": "^3.0.0",
		"@actions/exec": "^3.0.0",
		"@actions/github": "^9.1.0",
		"@octokit/rest": "^22.0.1",
		"axios": "^1.15.2",
		"moment": "^2.30.1"
	},
	"devDependencies": {
		"@remato/prettier-config": "^1.1.0",
		"esbuild": "^0.28.0",
		"oxlint": "^1.60.0",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3"
	},
	"prettier": "@remato/prettier-config"
}
